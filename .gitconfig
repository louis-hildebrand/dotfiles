[init]
    defaultBranch = main
[user]
    email = louis.hildebrand@mail.mcgill.ca
    name = Louis Hildebrand
[credential "https://dev.azure.com"]
    useHttpPath = true
[pull]
    rebase = true
[alias]
    s = 'status'
    a = 'add'
    c = 'commit'
    sw = 'switch'
    graph = 'log --graph --all --oneline'
    df = diff
[push]
	default = simple
[merge]
	defaultToUpstream = true
